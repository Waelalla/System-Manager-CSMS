# ============================================================
#  CSMS — Customer Service Management System
#  Environment Variables Reference
#  Copy this file to .env and fill in the values.
# ============================================================

# -----------------------------------------------------------
# Database
# -----------------------------------------------------------
# Full PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/csms_db
DATABASE_URL=postgresql://user:password@localhost:5432/csms_db

# -----------------------------------------------------------
# JWT Secrets  (REQUIRED in production — must be long random strings)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_in_production

# -----------------------------------------------------------
# CORS
# The exact origin the frontend is served from.
# Example: https://csms.example.com
# Leave blank to deny all cross-origin requests in production.
# In development this variable is ignored (all origins allowed).
# -----------------------------------------------------------
CORS_ORIGIN=https://csms.example.com

# -----------------------------------------------------------
# Server
# -----------------------------------------------------------
# Port the API server listens on (default: 8080)
PORT=8080

# Set to "production" on the VPS, leave unset (or "development") locally
NODE_ENV=production
